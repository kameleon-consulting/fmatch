# Local environment variables for development tooling.
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is listed in .gitignore.

# GitHub Personal Access Token (Fine-grained, kameleon-consulting/fmatch)
# Required scopes: Contents (write), Metadata (read)
# Generate at: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=your_token_here
